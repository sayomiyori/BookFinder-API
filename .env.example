# BookFinder API — пример переменных окружения
# Скопируйте в .env и заполните значения

# Приложение
APP_NAME=BookFinder API
DEBUG=false

# Секретный ключ для JWT (сгенерируйте: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# База данных (для разработки можно SQLite через sqlite+aiosqlite)
# PostgreSQL:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookfinder

# SQLite (разработка):
# DATABASE_URL=sqlite+aiosqlite:///./bookfinder.db

# Внешние API (опционально)
GOOGLE_BOOKS_API_BASE=https://www.googleapis.com/books/v1
# GOOGLE_VISION_API_KEY=
# GOOGLE_GEMINI_API_KEY=

# CORS (через запятую для нескольких origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
