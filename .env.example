# BookFinder API — пример переменных окружения
# Скопируйте в .env и заполните значения

# ── Приложение ────────────────────────────────────────────────────────────────
APP_NAME=BookFinder API
APP_VERSION=1.0.0
DEBUG=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ── База данных ───────────────────────────────────────────────────────────────
# SQLite (только для локальной разработки):
DATABASE_URL=sqlite+aiosqlite:///./bookfinder.db

# PostgreSQL (production / Railway):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookfinder
#
# Railway автоматически подставляет DATABASE_URL из PostgreSQL plugin.
# Формат postgres:// и postgresql:// нормализуется в postgresql+asyncpg://
# при старте — ничего дополнительно настраивать не нужно.

# ── Redis ─────────────────────────────────────────────────────────────────────
# Если REDIS_URL не задан или Redis недоступен — кэш молча отключается,
# API продолжает работать без него.
REDIS_URL=redis://localhost:6379/0

# Railway: используйте Reference Variable от Redis plugin:
# REDIS_URL=${{Redis.REDIS_URL}}

# ── Celery (фоновые задачи, опционально) ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Sentry (мониторинг ошибок, опционально) ───────────────────────────────────
# Получите DSN на sentry.io → Project → Settings → Client Keys
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── Внешние API (опционально) ─────────────────────────────────────────────────
GOOGLE_BOOKS_API_BASE=https://www.googleapis.com/books/v1
# GOOGLE_VISION_API_KEY=
# GOOGLE_GEMINI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Несколько origins — через запятую.
# Для Railway укажите URL вашего фронтенда или * для открытого API:
# CORS_ORIGINS=https://your-app.up.railway.app
# CORS_ORIGINS=*
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
